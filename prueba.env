APP_NAME="Alicia Cuenta"
APP_ENV=local
APP_BASE_URL=http://localhost:8000
LOGIN_TITLE="Ingreso seguro"
APP_LOGO_PATH=
APP_ROOT_PATH=
# APP_ROOT_PATH debe ser una ruta de disco, no una URL. Ejemplo Windows: C:/inetpub/wwwroot/cuenta
APP_INCLUDES_PATH=
APP_CONFIG_PATH=
APP_PUBLIC_PATH=
APP_STORAGE_PATH=
# Si IIS publica solo wwwroot y los includes están fuera, usar por ejemplo APP_INCLUDES_PATH=C:/inetpub/includes

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=alicia_cuenta
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Base remota MySQL para reportes futuros. Mantener apagada hasta configurar credenciales reales.
REPORT_DB_ENABLED=false
REPORT_DB_HOST=
REPORT_DB_PORT=3306
REPORT_DB_NAME=
REPORT_DB_USER=
REPORT_DB_PASS=
REPORT_DB_CHARSET=utf8mb4

LOG_ERRORS=true
DISPLAY_ERRORS=true
ERROR_LOG_PATH=storage/logs/app_errors.log

SESSION_NAME=ALICIA_CUENTA_SESSID
SESSION_TIMEOUT_MINUTES=30
