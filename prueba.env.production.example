APP_NAME="Alicia Cuenta"
APP_ENV=production
APP_BASE_URL=https://tudominio.com
LOGIN_TITLE="Ingreso seguro"
APP_LOGO_PATH=
APP_ROOT_PATH=
# APP_ROOT_PATH debe ser una ruta de disco, no una URL. Ejemplo Windows: C:/inetpub/wwwroot/cuenta
APP_INCLUDES_PATH=
APP_CONFIG_PATH=
APP_PUBLIC_PATH=
APP_STORAGE_PATH=
BRANCH_DB_PASSWORD_KEY="CAMBIAR_LLAVE_LARGA_ALEATORIA_PARA_SUCURSALES"
# Si IIS publica solo wwwroot y los includes están fuera, usar por ejemplo APP_INCLUDES_PATH=C:/inetpub/includes

DB_HOST=10.0.0.10
DB_PORT=3306
DB_NAME=alicia_cuenta
DB_USER=alicia_app
DB_PASS="CAMBIAR_PASSWORD_SEGURO"
DB_CHARSET=utf8mb4

# Base remota MySQL para reportes futuros.
REPORT_DB_ENABLED=true
REPORT_DB_HOST=reportes.mysql.remoto.com
REPORT_DB_PORT=3306
REPORT_DB_NAME=alicia_reportes
REPORT_DB_USER=alicia_reportes
REPORT_DB_PASS="CAMBIAR_PASSWORD_REPORTES"
REPORT_DB_CHARSET=utf8mb4

LOG_ERRORS=true
DISPLAY_ERRORS=false
ERROR_LOG_PATH=/var/log/alicia-cuenta/app_errors.log

SESSION_NAME=ALICIA_CUENTA_SESSID
SESSION_TIMEOUT_MINUTES=30
